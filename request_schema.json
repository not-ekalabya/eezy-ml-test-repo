{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/predict-request.schema.json",
  "title": "PredictRequest",
  "description": "Request body for POST /predict.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "features"
  ],
  "properties": {
    "features": {
      "description": "Either a single chat represented as a list of message objects, or a batch represented as a list of chat message lists.",
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/chatMessage"
          }
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/chatMessage"
            }
          }
        }
      ]
    },
    "max_new_tokens": {
      "type": "integer",
      "minimum": 1,
      "default": 96,
      "description": "Maximum number of new tokens to generate."
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "default": 0.7,
      "description": "Sampling temperature. Lower values are more deterministic."
    },
    "top_p": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1,
      "default": 0.9,
      "description": "Nucleus sampling threshold."
    },
    "enable_thinking": {
      "type": "boolean",
      "default": true,
      "description": "Whether to enable the model's thinking mode when supported."
    }
  },
  "$defs": {
    "chatMessage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "content"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "examples": [
    {
      "features": [
        {
          "role": "user",
          "content": "Answer with one short sentence about deployment."
        }
      ],
      "max_new_tokens": 96,
      "temperature": 0.7,
      "top_p": 0.9,
      "enable_thinking": true
    },
    {
      "features": [
        [
          {
            "role": "user",
            "content": "Return the word one."
          }
        ],
        [
          {
            "role": "user",
            "content": "Return the word two."
          }
        ],
        [
          {
            "role": "user",
            "content": "Return the word three."
          }
        ]
      ],
      "temperature": 0.2,
      "top_p": 0.95
    }
  ]
}
